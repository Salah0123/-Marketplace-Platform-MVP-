  "components": {
    "schemas": {
      "AddRoleCommand": {
        "required": [
          "role",
          "roleKey",
          "displayName"
        ],
        "type": "object",
        "properties": {
          "role": {
            "type": "string"
          },
          "roleKey": {
            "type": "string"
          },
          "displayName": {
            "type": "string"
          }
        }
      },
      "CreateServiceRequestCommand": {
        "required": [
          "title",
          "description",
          "latitude",
          "longitude",
          "userId"
        ],
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "latitude": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "longitude": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          },
          "userId": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "GetTokenQuery": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "RegisterUserCommand": {
        "required": [
          "email",
          "password",
          "name",
          "createdBy"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "createdBy": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "ServiceRequestDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  },
